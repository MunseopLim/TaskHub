{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskHub Links",
  "description": "A list of useful web links.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "description": "The display name for the link."
      },
      "link": {
        "type": "string",
        "description": "The URL to open.",
        "format": "uri"
      }
    },
    "required": ["title", "link"]
  }
}