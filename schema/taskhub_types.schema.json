{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskHub Type Configuration",
  "description": "Custom type sizes and alignment for struct size calculation in hover tooltips.",
  "type": "object",
  "properties": {
    "types": {
      "type": "object",
      "description": "Type definitions with size and alignment.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Size in bytes."
          },
          "alignment": {
            "type": "integer",
            "minimum": 1,
            "description": "Alignment requirement in bytes."
          }
        },
        "required": ["size", "alignment"]
      },
      "examples": [
        {
          "MyCustomType": { "size": 8, "alignment": 4 },
          "HANDLE": { "size": 8, "alignment": 8 }
        }
      ]
    },
    "packingAlignment": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16,
      "default": 8,
      "description": "Default struct packing alignment (1, 2, 4, 8, 16). Use 1 for packed structs."
    },
    "memoryMap": {
      "type": "object",
      "description": "Memory map configuration for ELF/AXF memory visualization.",
      "properties": {
        "regions": {
          "type": "array",
          "description": "Memory regions (FLASH, RAM, etc.) with origin address and total size.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Region name (e.g., FLASH, RAM, DTCM, ITCM)."
              },
              "origin": {
                "type": "integer",
                "minimum": 0,
                "description": "Start address of the memory region."
              },
              "size": {
                "type": "integer",
                "minimum": 1,
                "description": "Total size of the memory region in bytes."
              }
            },
            "required": ["name", "origin", "size"]
          }
        }
      }
    }
  },
  "examples": [
    {
      "types": {
        "HANDLE": { "size": 8, "alignment": 8 },
        "PVOID": { "size": 8, "alignment": 8 },
        "SIZE_T": { "size": 8, "alignment": 8 }
      },
      "packingAlignment": 8
    },
    {
      "types": {
        "MyPackedStruct": { "size": 12, "alignment": 1 }
      },
      "packingAlignment": 1
    }
  ]
}
