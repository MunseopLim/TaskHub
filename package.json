{
  "name": "taskhub",
  "displayName": "TaskHub",
  "description": "A customizable sidebar for running tasks and workflows in VS Code.",
  "icon": "media/h_icon.png",
  "publisher": "Munseop",
  "version": "0.2.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/munseoplim/TaskHub.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": [
          "/.vscode/actions.json",
          "/media/actions.json",
          "/media/actions_example.json"
        ],
        "url": "./schema/actions.schema.json"
      },
      {
        "fileMatch": [
          "/.vscode/links.json",
          "/media/links.json",
          "/media/links_example.json"
        ],
        "url": "./schema/links.schema.json"
      },
      {
        "fileMatch": [
          "/.vscode/favorites.json",
          "/media/favorites_example.json"
        ],
        "url": "./schema/favorites.schema.json"
      }
    ],
    "configuration": {
      "title": "TaskHub",
      "properties": {
        "taskhub.showTaskStatus": {
          "type": "boolean",
          "default": true,
          "description": "Show status indicators (running, success, failure) for actions in the Main view."
        },
        "taskhub.pipeline.showVerboseLogs": {
          "type": "boolean",
          "default": false,
          "description": "If true, shows detailed logs in the output panel when executing a pipeline. By default, only minimal status messages are shown."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mainView",
          "title": "TaskHub",
          "icon": "media/h_icon.svg"
        }
      ]
    },
    "views": {
      "mainView": [
        {
          "id": "mainView.main",
          "name": "Main",
          "icon": "media/m_icon.svg"
        },
        {
          "id": "mainView.link",
          "name": "Link",
          "icon": "media/l_icon.svg"
        },
        {
          "id": "mainView.favorite",
          "name": "Favorite Files",
          "icon": "media/f_icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "taskhub.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "taskhub.openLink",
        "title": "Open Link"
      },
      {
        "command": "taskhub.copyLink",
        "title": "Copy Link"
      },
      {
        "command": "taskhub.goToLink",
        "title": "Go to Link"
      },
      {
        "command": "taskhub.executeAction",
        "title": "Execute Action"
      },
      {
        "command": "taskhub.stopAction",
        "title": "Stop Action",
        "icon": "$(primitive-square)"
      },
      {
        "command": "taskhub.showVersion",
        "title": "Show Extension Version"
      },
      {
                  "command": "taskhub.showFilePicker",        "title": "Select and Run File"
      },
      {
        "command": "taskhub.openFavoriteFile",
        "title": "Open Favorite File"
      },
      {
        "command": "taskhub.editFavorites",
        "title": "Edit Favorites",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.editLinks",
        "title": "Edit Links",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.editActions",
        "title": "Edit Actions",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.addFavoriteFile",
        "title": "Add Existing File to Favorites",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.deleteFavorite",
        "title": "Delete Favorite",
        "icon": "$(trash)"
      },
      {
        "command": "taskhub.deleteLink",
        "title": "Delete Link",
        "icon": "$(trash)"
      },
      {
        "command": "taskhub.addOpenFileToFavorites",
        "title": "Add Open File to Favorites",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.showExampleJson",
        "title": "Show Example JSON"
      },
      {
        "command": "taskhub.showExampleJsonQuickPick",
        "title": "Show Example JSON Quick Pick"
      },
      {
        "command": "taskhub.terminateAllTasks",
        "title": "Terminate All Tasks",
        "icon": "$(primitive-square)"
      },
      {
        "command": "taskhub.openSettings",
        "title": "TaskHub: Open Extension Settings"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskhub.editFavorites",
          "when": "view == mainView.favorite",
          "group": "navigation"
        },
        {
          "command": "taskhub.addFavoriteFile",
          "when": "view == mainView.favorite",
          "group": "navigation"
        },
        {
          "command": "taskhub.editLinks",
          "when": "view == mainView.link",
          "group": "navigation"
        },
        {
          "command": "taskhub.editActions",
          "when": "view == mainView.main",
          "group": "navigation"
        },
        {
          "command": "taskhub.terminateAllTasks",
          "when": "view == mainView.main",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "taskhub.addOpenFileToFavorites",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "taskhub.copyLink",
          "when": "view == mainView.link && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.goToLink",
          "when": "view == mainView.link && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.deleteLink",
          "when": "view == mainView.link && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.deleteFavorite",
          "when": "view == mainView.favorite && viewItem == favoriteItem",
          "group": "inline"
        },
        {
          "command": "taskhub.showExampleJsonQuickPick",
          "when": "view == mainView.main && viewItem == versionItem",
          "group": "inline"
        },
        {
          "command": "taskhub.stopAction",
          "when": "view == mainView.main && viewItem == runningAction",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.75.0",
    "ajv": "^8.17.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^5.3.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "mocha": "^11.7.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0"
  }
}