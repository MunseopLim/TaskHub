{
  "name": "firmware-toolkit",
  "displayName": "firmware-toolkit",
  "description": "Firmware Toolkit",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:mainView.main",
    "onView:mainView.link",
    "onView:mainView.favorite"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mainView",
          "title": "Firmware Toolkit",
          "icon": "media/h_icon.svg"
        }
      ]
    },
    "views": {
      "mainView": [
        {
          "id": "mainView.main",
          "name": "Main"
        },
        {
          "id": "mainView.link",
          "name": "Link"
        },
        {
          "id": "mainView.favorite",
          "name": "Favorite"
        }
      ]
    },
    "commands": [
      {
        "command": "firmware-toolkit.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "firmware-toolkit.openLink",
        "title": "Open Link"
      },
      {
        "command": "firmware-toolkit.copyLink",
        "title": "Copy Link"
      },
      {
        "command": "firmware-toolkit.goToLink",
        "title": "Go to Link"
      },
      {
        "command": "firmware-toolkit.executeAction",
        "title": "Execute Action"
      },
      {
        "command": "firmware-toolkit.showVersion",
        "title": "Show Extension Version"
      },
      {
        "command": "firmware-toolkit.showExecutablePicker",
        "title": "Select and Run Executable"
      },
      {
        "command": "firmware-toolkit.openFavoriteFile",
        "title": "Open Favorite File"
      },
      {
        "command": "firmware-toolkit.editFavorites",
        "title": "Edit Favorites",
        "icon": "$(pencil)"
      },
      {
        "command": "firmware-toolkit.editLinks",
        "title": "Edit Links",
        "icon": "$(pencil)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "firmware-toolkit.editFavorites",
          "when": "view == mainView.favorite",
          "group": "navigation"
        },
        {
          "command": "firmware-toolkit.editLinks",
          "when": "view == mainView.link",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "firmware-toolkit.copyLink",
          "when": "view == mainView.link && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "firmware-toolkit.goToLink",
          "when": "view == mainView.link && viewItem == linkItem",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^5.3.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "mocha": "^11.7.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  }
}
