{
  "name": "taskhub",
  "displayName": "TaskHub",
  "description": "A customizable sidebar for running tasks and workflows in VS Code.",
  "icon": "media/h_icon.png",
  "publisher": "Munseop",
  "version": "0.4.8",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MunseopLim/TaskHub.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "TaskHub는 워크스페이스의 .vscode/actions.json 으로부터 shell/command 태스크를 실행할 수 있으므로, 신뢰할 수 없는 워크스페이스에서는 비활성화됩니다. TaskHub can execute shell/command tasks defined in a workspace's .vscode/actions.json, so it is disabled in untrusted workspaces."
    }
  },
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": [
          "/.vscode/actions.json",
          "/media/actions.json",
          "/media/actions_example.json"
        ],
        "url": "./schema/actions.schema.json"
      },
      {
        "fileMatch": [
          "/.vscode/links.json",
          "/media/links.json",
          "/media/links_example.json"
        ],
        "url": "./schema/links.schema.json"
      },
      {
        "fileMatch": [
          "/.vscode/favorites.json",
          "/media/favorites_example.json"
        ],
        "url": "./schema/favorites.schema.json"
      },
      {
        "fileMatch": [
          "/.vscode/taskhub_types.json"
        ],
        "url": "./schema/taskhub_types.schema.json"
      }
    ],
    "configuration": {
      "title": "TaskHub",
      "properties": {
        "taskhub.showTaskStatus": {
          "type": "boolean",
          "default": true,
          "description": "Show status indicators (running, success, failure) for actions in the Actions view."
        },
        "taskhub.pipeline.showVerboseLogs": {
          "type": "boolean",
          "default": false,
          "description": "If true, shows detailed logs in the output panel when executing a pipeline. By default, only minimal status messages are shown."
        },
        "taskhub.pipeline.pythonIoEncoding": {
          "type": "string",
          "default": "utf-8",
          "markdownDescription": "Value to assign to the `PYTHONIOENCODING` environment variable for commands launched by TaskHub. Set to an empty string to avoid forcing an encoding or provide values such as `utf-8:ignore` for compatibility."
        },
        "taskhub.pipeline.windowsPowerShellEncoding": {
          "type": "string",
          "enum": [
            "utf8",
            "system"
          ],
          "default": "utf8",
          "description": "Controls how TaskHub configures PowerShell output on Windows. Use `system` to keep the current console code page for legacy tools that do not recognise UTF-8 (code page 65001)."
        },
        "taskhub.history.maxItems": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of action history items to keep."
        },
        "taskhub.history.showPanel": {
          "type": "boolean",
          "default": true,
          "description": "Show or hide the History panel in the TaskHub sidebar."
        },
        "taskhub.hover.numberBase.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable number base conversion hover tooltip for C/C++ files. Shows binary, decimal, and hexadecimal representations when hovering over numeric literals."
        },
        "taskhub.experimental.bitOperationHover.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**[Experimental]** Show bit operation results in hover tooltips for C/C++ files.\n\nDisplays calculation results for:\n- Variable operations: `value |= 0x80` (shows Before/After)\n- Constant expressions: `1U << 5` (shows Left/Result)\n\n**Supported patterns:**\n- ✅ `value & 0xFF` (variable & literal)\n- ✅ `1U << 5` (constant expressions)\n- ❌ `a ^ b` (variable & variable - not supported)\n\n⚠️ This feature is experimental and may change in future versions."
        },
        "taskhub.preset.selected": {
          "type": "string",
          "default": "none",
          "markdownDescription": "Select a preset to automatically apply predefined actions.\n\n- **none**: Use only workspace actions\n- **example**: Example preset with Git and Build commands\n- Or enter a custom preset ID from extension or workspace `.vscode/presets/` folder\n\nPresets are merged with workspace `.vscode/actions.json` (workspace actions take priority)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mainView",
          "title": "TaskHub",
          "icon": "media/h_icon.svg"
        }
      ]
    },
    "views": {
      "mainView": [
        {
          "id": "mainView.main",
          "name": "Actions",
          "icon": "media/m_icon.svg"
        },
        {
          "id": "mainView.linkBuiltin",
          "name": "Built-in Links",
          "icon": "media/l_icon.svg"
        },
        {
          "id": "mainView.linkWorkspace",
          "name": "Workspace Links",
          "icon": "media/l_icon.svg"
        },
        {
          "id": "mainView.favorite",
          "name": "Favorite Files",
          "icon": "media/f_icon.svg"
        },
        {
          "id": "mainView.history",
          "name": "History",
          "icon": "media/r_icon.svg",
          "when": "config.taskhub.history.showPanel"
        }
      ]
    },
    "commands": [
      {
        "command": "taskhub.openLink",
        "title": "Open Link"
      },
      {
        "command": "taskhub.copyLink",
        "title": "Copy Link"
      },
      {
        "command": "taskhub.goToLink",
        "title": "Go to Link"
      },
      {
        "command": "taskhub.addLink",
        "title": "TaskHub: Add Link",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.editWorkspaceLink",
        "title": "TaskHub: Edit Workspace Link",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.searchLinks",
        "title": "TaskHub: Search Links",
        "icon": "$(search)"
      },
      {
        "command": "taskhub.searchFavorites",
        "title": "TaskHub: Search Favorites",
        "icon": "$(search)"
      },
      {
        "command": "taskhub.createAction",
        "title": "TaskHub: Create Action",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.executeAction",
        "title": "Execute Action"
      },
      {
        "command": "taskhub.previewAction",
        "title": "Preview Run (Dry-run)",
        "category": "TaskHub",
        "icon": "$(eye)"
      },
      {
        "command": "taskhub.stopAction",
        "title": "Stop Action",
        "icon": "$(primitive-square)"
      },
      {
        "command": "taskhub.showVersion",
        "title": "Show Extension Version"
      },
      {
        "command": "taskhub.showFilePicker",
        "title": "Select and Run File"
      },
      {
        "command": "taskhub.openFavoriteFile",
        "title": "Open Favorite File"
      },
      {
        "command": "taskhub.editFavorites",
        "title": "Edit Favorites",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.editLinks",
        "title": "Edit Links",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.editActions",
        "title": "Edit Actions",
        "icon": "$(pencil)"
      },
      {
        "command": "taskhub.addFavoriteFile",
        "title": "Add Existing File to Favorites",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.deleteFavorite",
        "title": "Delete Favorite",
        "icon": "$(trash)"
      },
      {
        "command": "taskhub.deleteLink",
        "title": "Delete Link",
        "icon": "$(trash)"
      },
      {
        "command": "taskhub.addOpenFileToFavorites",
        "title": "Add Open File to Favorites",
        "icon": "$(add)"
      },
      {
        "command": "taskhub.showExampleJson",
        "title": "Show Example JSON"
      },
      {
        "command": "taskhub.showExampleJsonQuickPick",
        "title": "Show Example JSONs",
        "icon": "$(lightbulb)"
      },
      {
        "command": "taskhub.showChangelog",
        "title": "Show Changelog"
      },
      {
        "command": "taskhub.terminateAllActions",
        "title": "Terminate All Actions",
        "icon": "$(primitive-square)"
      },
      {
        "command": "taskhub.openSettings",
        "title": "TaskHub: Open Extension Settings"
      },
      {
        "command": "taskhub.rerunFromHistory",
        "title": "Re-run Action"
      },
      {
        "command": "taskhub.viewHistoryOutput",
        "title": "View Output",
        "icon": "$(output)"
      },
      {
        "command": "taskhub.deleteHistoryItem",
        "title": "Delete History Item",
        "icon": "$(trash)"
      },
      {
        "command": "taskhub.clearAllHistory",
        "title": "Clear All History",
        "icon": "$(clear-all)"
      },
      {
        "command": "taskhub.toggleHistoryPanel",
        "title": "TaskHub: Show History Panel"
      },
      {
        "command": "taskhub.applyPreset",
        "title": "TaskHub: Apply Preset"
      },
      {
        "command": "taskhub.saveAsPreset",
        "title": "TaskHub: Save as Preset"
      },
      {
        "command": "taskhub.openJsonEditor",
        "title": "TaskHub: Open JSON Editor",
        "icon": "$(edit)"
      },
      {
        "command": "taskhub.openJsonEditorFromUri",
        "title": "Open with JSON Editor",
        "category": "TaskHub"
      },
      {
        "command": "taskhub.showMemoryMap",
        "title": "Show Memory Map",
        "category": "TaskHub"
      },
      {
        "command": "taskhub.memoryMapGoToSymbol",
        "title": "Memory Map: Go to Symbol",
        "category": "TaskHub"
      },
      {
        "command": "taskhub.exportActions",
        "title": "TaskHub: Export Actions",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "taskhub.importActions",
        "title": "TaskHub: Import Actions",
        "icon": "$(cloud-download)"
      },
      {
        "command": "taskhub.exportActionItem",
        "title": "Export Action",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "taskhub.showHexViewer",
        "title": "Open Hex Viewer",
        "category": "TaskHub"
      }
    ],
    "keybindings": [
      {
        "command": "taskhub.memoryMapGoToSymbol",
        "key": "ctrl+shift+o",
        "when": "activeWebviewPanelId == 'taskhub.memoryMap'"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskhub.searchFavorites",
          "when": "view == mainView.favorite",
          "group": "navigation@1"
        },
        {
          "command": "taskhub.addFavoriteFile",
          "when": "view == mainView.favorite",
          "group": "navigation@2"
        },
        {
          "command": "taskhub.editFavorites",
          "when": "view == mainView.favorite",
          "group": "navigation@3"
        },
        {
          "command": "taskhub.searchLinks",
          "when": "view == mainView.linkWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "taskhub.addLink",
          "when": "view == mainView.linkWorkspace",
          "group": "navigation@2"
        },
        {
          "command": "taskhub.editLinks",
          "when": "view == mainView.linkWorkspace",
          "group": "navigation@3"
        },
        {
          "command": "taskhub.showExampleJsonQuickPick",
          "when": "view == mainView.main",
          "group": "navigation@0"
        },
        {
          "command": "taskhub.editActions",
          "when": "view == mainView.main",
          "group": "navigation"
        },
        {
          "command": "taskhub.terminateAllActions",
          "when": "view == mainView.main",
          "group": "navigation@1"
        },
        {
          "command": "taskhub.createAction",
          "when": "view == mainView.main",
          "group": "navigation@2"
        },
        {
          "command": "taskhub.importActions",
          "when": "view == mainView.main",
          "group": "navigation@3"
        },
        {
          "command": "taskhub.clearAllHistory",
          "when": "view == mainView.history",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "taskhub.addOpenFileToFavorites",
          "group": "navigation"
        },
        {
          "command": "taskhub.openJsonEditorFromUri",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "taskhub.openJsonEditorFromUri",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "taskhub.openJsonEditorFromUri",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "taskhub.copyLink",
          "when": "(view == mainView.linkWorkspace || view == mainView.linkBuiltin) && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.goToLink",
          "when": "(view == mainView.linkWorkspace || view == mainView.linkBuiltin) && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.editWorkspaceLink",
          "when": "view == mainView.linkWorkspace && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.deleteLink",
          "when": "view == mainView.linkWorkspace && viewItem == linkItem",
          "group": "inline"
        },
        {
          "command": "taskhub.deleteFavorite",
          "when": "view == mainView.favorite && viewItem == favoriteItem",
          "group": "inline"
        },
        {
          "command": "taskhub.previewAction",
          "when": "view == mainView.main && viewItem == action",
          "group": "context@0"
        },
        {
          "command": "taskhub.previewAction",
          "when": "view == mainView.main && viewItem == succeededAction",
          "group": "context@0"
        },
        {
          "command": "taskhub.previewAction",
          "when": "view == mainView.main && viewItem == failedAction",
          "group": "context@0"
        },
        {
          "command": "taskhub.exportActionItem",
          "when": "view == mainView.main && viewItem == action",
          "group": "context@1"
        },
        {
          "command": "taskhub.exportActionItem",
          "when": "view == mainView.main && viewItem == folder",
          "group": "context@1"
        },
        {
          "command": "taskhub.stopAction",
          "when": "view == mainView.main && viewItem == runningAction",
          "group": "inline"
        },
        {
          "command": "taskhub.viewHistoryOutput",
          "when": "view == mainView.history && viewItem == historyItemWithOutput",
          "group": "inline@1"
        },
        {
          "command": "taskhub.deleteHistoryItem",
          "when": "view == mainView.history && (viewItem == historyItem || viewItem == historyItemWithOutput)",
          "group": "inline@2"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "taskhub.hexEditor",
        "displayName": "TaskHub Hex Viewer",
        "selector": [
          {
            "filenamePattern": "*.hex"
          },
          {
            "filenamePattern": "*.ihex"
          },
          {
            "filenamePattern": "*.srec"
          },
          {
            "filenamePattern": "*.s19"
          },
          {
            "filenamePattern": "*.s28"
          },
          {
            "filenamePattern": "*.s37"
          },
          {
            "filenamePattern": "*.bin"
          },
          {
            "filenamePattern": "*.dat"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "ajv": "^8.17.1",
    "chai": "^5.3.1",
    "esbuild": "^0.25.8",
    "eslint": "^10.0.0",
    "mocha": "^11.0.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.17"
  }
}
