[
  {
    "id": "button.testLiveStream",
    "title": "1. Test Live Stream (Default)",
    "action": {
      "description": "Select a file and stream its metadata to the shared terminal.",
      "tasks": [
        {
          "id": "selectFileForStream",
          "type": "fileDialog",
          "options": {
            "openLabel": "Select any file for live stream test"
          }
        },
        {
          "id": "echoFileStream",
          "type": "shell",
          "command": "echo [STREAM] Path=${selectFileForStream.path}, Dir=${selectFileForStream.dir}, Name=${selectFileForStream.name}, NameOnly=${selectFileForStream.fileNameOnly}, Ext=${selectFileForStream.fileExt}",
          "revealTerminal": "always"
        }
      ]
    },
    "successMessage": "Live stream test completed. Check the terminal output.",
    "failMessage": "Live stream test failed. Please try again."
  },
  {
    "id": "button.testCaptureToFile",
    "title": "2. Test Capture to File",
    "action": {
      "description": "Capture command output and save it as a file in the workspace.",
      "tasks": [
        {
          "id": "selectFileForFile",
          "type": "fileDialog",
          "options": {
            "openLabel": "Select any file for file capture test"
          }
        },
        {
          "id": "echoForFile",
          "type": "shell",
          "command": "echo [CAPTURED FOR FILE] Path=${selectFileForFile.path}, Dir=${selectFileForFile.dir}, Name=${selectFileForFile.name}, NameOnly=${selectFileForFile.fileNameOnly}, Ext=${selectFileForFile.fileExt}",
          "passTheResultToNextTask": true,
          "output": {
            "mode": "file",
            "filePath": "${workspaceFolder}/test_output.txt",
            "overwrite": true
          }
        }
      ]
    }
  },
  {
    "id": "button.testCaptureToEditor",
    "title": "3. Test Capture to Editor",
    "action": {
      "description": "Capture command output and display it in a temporary editor document.",
      "tasks": [
        {
          "id": "selectFileForEditor",
          "type": "fileDialog",
          "options": {
            "openLabel": "Select any file for editor capture test"
          }
        },
        {
          "id": "echoForEditor",
          "type": "shell",
          "command": "echo [CAPTURED FOR EDITOR] Path=${selectFileForEditor.path}, Dir=${selectFileForEditor.dir}, Name=${selectFileForEditor.name}, NameOnly=${selectFileForEditor.fileNameOnly}, Ext=${selectFileForEditor.fileExt}",
          "passTheResultToNextTask": true,
          "output": {
            "mode": "editor",
            "title": "Captured Result"
          }
        }
      ]
    }
  },
  {
    "id": "folder.parser",
    "type": "folder",
    "title": "Firmware Parser",
    "children": [
      {
        "id": "button.unzipAndParse",
        "title": "From ZIP file...",
        "action": {
          "description": "Unzip a firmware archive and run the parser on the extracted contents.",
          "tasks": [
            {
              "id": "select_zip_file",
              "type": "fileDialog",
              "options": {
                "openLabel": "Select ZIP file",
                "filters": {
                  "Zip files": [
                    "zip"
                  ]
                }
              }
            },
            {
              "id": "unzip_the_file",
              "type": "unzip",
              "tool": {
                "windows": "C:\\Program Files\\7-Zip\\7z.exe",
                "macos": "/opt/homebrew/bin/7z"
              },
              "inputs": {
                "file": "select_zip_file"
              }
            },
            {
              "id": "run_py_parser_from_zip",
              "type": "shell",
              "command": {
                "windows": "py E:\\dump\\parser.py \"${unzip_the_file.outputDir}\\${select_zip_file.fileNameOnly}\"",
                "macos": "python3 /Users/munseop/code/test/script.py \"${unzip_the_file.outputDir}/${select_zip_file.fileNameOnly}\""
              },
              "output": {
                "mode": "terminal"
              }
            }
          ]
        }
      },
      {
        "id": "button.selectFolderAndParse",
        "title": "From Folder...",
        "action": {
          "description": "Run the firmware parser on an already extracted firmware folder.",
          "tasks": [
            {
              "id": "select_target_folder",
              "type": "folderDialog",
              "options": {
                "openLabel": "Select folder to parse"
              }
            },
            {
              "id": "run_parser_on_folder",
              "type": "shell",
              "command": {
                "macos": "python3 /Users/munseop/code/test/script.py \"${select_target_folder.path}\"",
                "windows": "py E:\\dump\\parser.py \"${select_target_folder.path}\""
              },
              "passTheResultToNextTask": true,
              "output": {
                "mode": "editor",
                "title": "Parser Output"
              }
            }
          ]
        }
      }
    ]
  },
  {
    "id": "button.createFirmwareArchive",
    "title": "Create Firmware Archive from Folder...",
    "action": {
      "description": "Compress a selected folder into a firmware ZIP archive.",
      "successMessage": "Firmware archive created successfully!",
      "tasks": [
        {
          "id": "select_folder_to_zip",
          "type": "folderDialog",
          "options": {
            "openLabel": "Select folder to compress"
          }
        },
        {
          "id": "zip_the_folder",
          "type": "zip",
          "tool": {
            "windows": "C:\\Program Files\\7-Zip\\7z.exe",
            "macos": "/opt/homebrew/bin/7z"
          },
          "source": "${select_folder_to_zip.path}",
          "archive": "${select_folder_to_zip.path}.zip"
        },
        {
          "id": "confirm_zip_creation",
          "type": "shell",
          "command": "echo Firmware archive created at: ${zip_the_folder.archivePath}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "folder.revealTerminalTest",
    "type": "folder",
    "title": "Test revealTerminal",
    "children": [
      {
        "id": "test.reveal.always",
        "title": "Always (Default)",
        "action": {
          "description": "Demonstrate the default behavior where the terminal is always revealed.",
          "tasks": [
            {
              "id": "echo.always",
              "type": "shell",
              "command": "echo 'This terminal should always be revealed.'",
              "revealTerminal": "always"
            }
          ]
        }
      },
      {
        "id": "test.reveal.silent",
        "title": "Silent",
        "action": {
          "description": "Run a task without revealing the terminal unless it is already visible.",
          "tasks": [
            {
              "id": "echo.silent",
              "type": "shell",
              "command": "echo 'This task should run silently without revealing the terminal unless it was already open.'",
              "revealTerminal": "silent"
            }
          ]
        }
      },
      {
        "id": "test.reveal.never",
        "title": "Never",
        "action": {
          "description": "Run a task that keeps the terminal hidden even while it executes.",
          "tasks": [
            {
              "id": "echo.never",
              "type": "shell",
              "command": "echo 'This task should run without ever revealing the terminal.'",
              "revealTerminal": "never"
            }
          ]
        }
      }
    ]
  },
  {
    "id": "test.isOneShot",
    "title": "Test isOneShot",
    "action": {
      "description": "Show how a one-shot background task runs alongside immediate follow-up steps.",
      "tasks": [
        {
          "id": "long.running.task",
          "type": "shell",
          "command": "echo 'Starting 10-second background task...'; sleep 10; echo 'Background task finished.'",
          "isOneShot": true
        },
        {
          "id": "immediate.task",
          "type": "shell",
          "command": "echo 'This message should appear immediately, without waiting for the 10-second task to finish.'"
        }
      ]
    }
  },
  {
    "id": "test.sharedTerminal",
    "title": "Test Shared Terminal",
    "action": {
      "description": "Illustrate multiple tasks writing to the same shared terminal instance.",
      "tasks": [
        {
          "id": "shared.task.1",
          "type": "shell",
          "command": "echo 'Task 1: This should appear in the shared terminal.'"
        },
        {
          "id": "shared.task.2",
          "type": "shell",
          "command": "echo 'Task 2: This should appear in the SAME shared terminal.'"
        }
      ]
    }
  }
]
