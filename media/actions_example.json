[
  {
    "id": "action.simple.echo",
    "title": "Echo Message (Live Stream)",
    "action": {
      "description": "Run a single shell command that streams output to the terminal.",
      "tasks": [
        {
          "id": "echo_task",
          "type": "shell",
          "command": "echo Hello World from TaskHub!"
        }
      ]
    }
  },
  {
    "id": "action.pipeline.example",
    "title": "Pipeline: Select File & Save Output",
    "action": {
      "description": "Select a file, echo the path, and save the result to disk.",
      "tasks": [
        {
          "id": "select_file",
          "type": "fileDialog"
        },
        {
          "id": "echo_file",
          "type": "shell",
          "command": "echo Selected file: ${select_file.path}",
          "passTheResultToNextTask": true,
          "output": {
            "mode": "file",
            "filePath": "${workspaceFolder}/pipeline_output.txt",
            "overwrite": true
          }
        }
      ]
    }
  },
  {
    "id": "action.oneshot.example",
    "title": "Run GUI App (One-Shot)",
    "action": {
      "description": "Launch a GUI application without waiting for it to exit.",
      "tasks": [
        {
          "id": "run_notepad",
          "type": "shell",
          "command": {
            "windows": "notepad.exe"
          },
          "isOneShot": true
        }
      ]
    }
  },
  {
    "id": "action.zip.folder",
    "title": "Zip Folder And Confirm",
    "action": {
      "description": "Select a folder, create a ZIP archive, and announce the result in the terminal.",
      "tasks": [
        {
          "id": "select_folder",
          "type": "folderDialog",
          "options": {
            "openLabel": "Select folder to zip"
          }
        },
        {
          "id": "zip_folder",
          "type": "zip",
          "tool": {
            "windows": "C:\\Program Files\\7-Zip\\7z.exe",
            "macos": "/opt/homebrew/bin/7z"
          },
          "source": "${select_folder.path}",
          "archive": "${select_folder.path}.zip"
        },
        {
          "id": "announce_zip",
          "type": "shell",
          "command": "echo Archive created at: ${zip_folder.archivePath}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.string.manipulation",
    "title": "String Manipulation Helpers",
    "action": {
      "description": "Select a file and run several string manipulation helpers on the path.",
      "tasks": [
        {
          "id": "select_for_string",
          "type": "fileDialog"
        },
        {
          "id": "string_dir",
          "type": "stringManipulation",
          "function": "dirname",
          "input": "${select_for_string.path}"
        },
        {
          "id": "string_filename",
          "type": "stringManipulation",
          "function": "basename",
          "input": "${select_for_string.path}"
        },
        {
          "id": "string_clean_name",
          "type": "stringManipulation",
          "function": "basenameWithoutExtension",
          "input": "${select_for_string.path}"
        },
        {
          "id": "string_upper_name",
          "type": "stringManipulation",
          "function": "toUpperCase",
          "input": "${string_clean_name.output}"
        },
        {
          "id": "report_strings",
          "type": "shell",
          "command": "echo Dir: ${string_dir.output} && echo File: ${string_filename.output} && echo Clean: ${string_clean_name.output} && echo Upper: ${string_upper_name.output}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.unzip.inputs",
    "title": "Unzip With Inputs And Direct Destination",
    "action": {
      "description": "Demonstrate how unzip tasks can consume archive/destination from prior steps or direct strings.",
      "tasks": [
        {
          "id": "select_zip_for_unzip",
          "type": "fileDialog",
          "options": {
            "filters": {
              "Archives": ["zip", "7z"]
            }
          }
        },
        {
          "id": "select_destination_for_unzip",
          "type": "folderDialog",
          "options": {
            "openLabel": "Select destination folder (will create subfolder)"
          }
        },
        {
          "id": "unzip_using_task_inputs",
          "type": "unzip",
          "tool": {
            "windows": "C:\\Program Files\\7-Zip\\7z.exe",
            "macos": "/opt/homebrew/bin/7z"
          },
          "inputs": {
            "archive": "select_zip_for_unzip",
            "destination": "select_destination_for_unzip"
          }
        },
        {
          "id": "unzip_using_direct_destination",
          "type": "unzip",
          "tool": {
            "windows": "C:\\Program Files\\7-Zip\\7z.exe",
            "macos": "/opt/homebrew/bin/7z"
          },
          "inputs": {
            "archive": "select_zip_for_unzip"
          },
          "destination": "${workspaceFolder}/.taskhub/unzip-output"
        }
      ]
    }
  },
  {
    "id": "action.inputbox.simple",
    "title": "InputBox: Enter Text",
    "action": {
      "description": "Prompt user for input and echo it",
      "tasks": [
        {
          "id": "input_name",
          "type": "inputBox",
          "prompt": "Enter your name",
          "placeHolder": "John Doe"
        },
        {
          "id": "echo_name",
          "type": "shell",
          "command": "echo Hello, ${input_name.value}!",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.inputbox.with.prefix",
    "title": "InputBox: With Prefix/Suffix",
    "action": {
      "description": "Demonstrate prefix and suffix in inputBox - user only enters the main value",
      "tasks": [
        {
          "id": "input_args",
          "type": "inputBox",
          "prompt": "Enter arguments (prefix '-g' will be added automatically)",
          "placeHolder": "Test 1234 123",
          "prefix": "-g ",
          "suffix": " --verbose"
        },
        {
          "id": "show_args",
          "type": "shell",
          "command": "echo Full command args: ${input_args.value}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.quickpick.simple",
    "title": "QuickPick: Select Environment",
    "action": {
      "description": "Select environment from predefined options",
      "tasks": [
        {
          "id": "select_env",
          "type": "quickPick",
          "placeHolder": "Select deployment environment",
          "items": ["dev", "staging", "production"]
        },
        {
          "id": "show_env",
          "type": "shell",
          "command": "echo Selected environment: ${select_env.value}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.quickpick.with.description",
    "title": "QuickPick: With Descriptions",
    "action": {
      "description": "Select option with detailed descriptions",
      "tasks": [
        {
          "id": "select_build",
          "type": "quickPick",
          "placeHolder": "Select build type",
          "items": [
            {
              "label": "debug",
              "description": "Debug build with symbols",
              "detail": "Best for development and debugging"
            },
            {
              "label": "release",
              "description": "Optimized release build",
              "detail": "Best for production deployment"
            },
            {
              "label": "profile",
              "description": "Release build with profiling",
              "detail": "For performance analysis"
            }
          ]
        },
        {
          "id": "show_build",
          "type": "shell",
          "command": "echo Build type: ${select_build.value}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.quickpick.multiple",
    "title": "QuickPick: Multiple Selection",
    "action": {
      "description": "Select multiple features to enable",
      "tasks": [
        {
          "id": "select_features",
          "type": "quickPick",
          "placeHolder": "Select features to enable (multiple selection)",
          "canPickMany": true,
          "items": ["authentication", "logging", "caching", "monitoring", "analytics"]
        },
        {
          "id": "show_features",
          "type": "shell",
          "command": "echo Enabled features: ${select_features.values}",
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "action.run.script.with.params",
    "title": "Complete Example: Run Script with Parameters",
    "action": {
      "description": "Select file, environment, and parameters to run a script",
      "successMessage": "Script executed successfully!",
      "tasks": [
        {
          "id": "select_script",
          "type": "fileDialog",
          "options": {
            "filters": {
              "Scripts": ["js", "py", "sh"]
            }
          }
        },
        {
          "id": "select_environment",
          "type": "quickPick",
          "placeHolder": "Select environment",
          "items": [
            {
              "label": "development",
              "description": "Development environment"
            },
            {
              "label": "staging",
              "description": "Staging environment"
            },
            {
              "label": "production",
              "description": "Production environment"
            }
          ]
        },
        {
          "id": "input_port",
          "type": "inputBox",
          "prompt": "Enter port number",
          "value": "3000",
          "placeHolder": "3000"
        },
        {
          "id": "input_extra_args",
          "type": "inputBox",
          "prompt": "Enter extra arguments (optional)",
          "placeHolder": "additional flags",
          "prefix": "--extra "
        },
        {
          "id": "run_script",
          "type": "shell",
          "command": "node ${select_script.path} --env ${select_environment.value} --port ${input_port.value} ${input_extra_args.value}",
          "revealTerminal": "always"
        }
      ]
    }
  }
]
