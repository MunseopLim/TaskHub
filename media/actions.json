[
  {
    "id": "button.build",
    "title": "Build",
    "action": {
      "type": "shell",
      "command": {
        "macos": "echo 'Building...' && sleep 1",
        "windows": {
          "cmd": "echo 'Building with cmd...' && timeout 1",
          "powershell": "echo 'Building with powershell...' && sleep 1"
        },
        "linux": "echo 'Building...' && sleep 1"
      },
      "cwd": "${workspaceFolder}",
      "revealTerminal": "always",
      "successMessage": "Build completed successfully!",
      "failMessage": "Build failed. Check terminal for details."
    }
  },
  {
    "id": "separator.1",
    "type": "separator",
    "title": "------------"
  },
  {
    "id": "button.analyzePackage",
    "title": "Analyze Firmware Package",
    "action": {
      "type": "pipeline",
      "steps": [
        {
          "id": "selectFile",
          "type": "fileDialog",
          "options": {
            "canSelectMany": false,
            "openLabel": "Select Package (.7z, .zip)",
            "filters": {
              "Archives": ["7z", "zip"]
            }
          }
        },
        {
          "id": "unzip",
          "type": "unzip",
          "tool": {
            "macos": "7za",
            "windows": "7z.exe",
            "linux": "7za"
          },
          "inputs": {
            "file": "selectFile"
          }
        },
        {
          "id": "getFileName",
          "type": "stringManipulation",
          "function": "stripExtension",
          "input": "${selectFile.name}"
        },
        {
          "id": "runScript",
          "type": "command",
          "command": "bash",
          "args": [
            "-c",
            "echo \"Parameter to script.py: ${unzip.outputDir}/${getFileName.output}\" && python3 \"/Users/munseop/code/test/script.py\" \"${unzip.outputDir}/${getFileName.output}\""
          ],
          "inputs": {
            "unzip": "unzip",
            "getFileName": "getFileName"
          },
          "output": {
            "showInEditor": true,
            "title": "Analysis Result"
          }
        }
      ],
      "successMessage": "Package analysis completed successfully!",
      "failMessage": "Package analysis failed."
    }
  },
  {
    "id": "button.openExplorer",
    "title": "Open Project Directory",
    "action": {
      "type": "shell",
      "command": {
        "macos": "open .",
        "windows": "explorer .",
        "linux": "xdg-open ."
      },
      "cwd": "${workspaceFolder}",
      "revealTerminal": "silent",
      "successMessage": "Project directory opened."
    }
  },
  {
    "id": "button.printEnv",
    "title": "Print Environment Variables",
    "action": {
      "type": "shell",
      "command": {
        "macos": "printenv && echo \"PATH=$PATH\"",
        "windows": {
          "cmd": "set && echo \"PATH=%PATH%\"",
          "powershell": "Get-ChildItem Env: ; echo \"PATH=$env:PATH\""
        },
        "linux": "printenv && echo \"PATH=$PATH\""
      },
      "cwd": "${workspaceFolder}",
      "revealTerminal": "always"
    }
  },
  {
    "id": "button.selectExecutable",
    "title": "Select Executable",
    "action": {
      "type": "executablePicker",
      "folder": "${workspaceFolder}/bin",
      "runCommand": "bash ${file}"
    }
  }
]