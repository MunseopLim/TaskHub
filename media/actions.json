[
  {
    "id": "button.showEnv",
    "title": "Show Environment Variables",
    "action": {
      "tasks": [
        {
          "id": "show_env_task",
          "type": "shell",
          "command": {
            "windows": "Get-ChildItem Env:",
            "linux": "printenv",
            "macos": "printenv"
          },
          "passTheResultToNextTask": false,
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "separator.0000",
    "title": "--------------------",
    "type": "separator"
  }
]
