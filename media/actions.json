[
  {
    "id": "defaultButton.showEnv",
    "title": "Show Environment Variables",
    "action": {
      "tasks": [
        {
          "id": "show_env_task",
          "type": "shell",
          "command": {
            "windows": "powershell -Command Get-ChildItem Env:",
            "linux": "printenv",
            "macos": "printenv"
          },
          "passTheResultToNextTask": false,
          "revealTerminal": "always"
        }
      ]
    }
  },
  {
    "id": "defaultButton.showProjectDir",
    "title": "Open Current Project Directory",
    "action": {
      "tasks": [
        {
          "id": "open_project_dir_task",
          "type": "shell",
          "command": {
            "windows": "explorer .",
            "linux": "xdg-open .",
            "macos": "open ."
          },
          "revealTerminal": "never",
          "isOneShot": true
        }
      ]
    }
  },
  {
    "id": "separator.0000",
    "title": "--------------------",
    "type": "separator"
  }
]
